# Django Settings
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=votre-domaine.com,127.0.0.1

# PostgreSQL Database
POSTGRES_DB=openlmis_dhis2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_DEFAULT_USER=rabbitmq
RABBITMQ_DEFAULT_PASS=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
CELERY_BROKER_URL=amqp://rabbitmq:rabbitmq@rabbitmq:5672//

# OpenLMIS API Configuration
OPENLMIS_BASE_URL=https://openlmis.example.org
OPENLMIS_CLIENT_ID=your-client-id
OPENLMIS_CLIENT_SECRET=your-client-secret
OPENLMIS_USERNAME=admin
OPENLMIS_PASSWORD=admin

# Sync Configuration
SYNC_DAY_OF_MONTH=5
SYNC_HOUR=2
SYNC_MINUTE=0
